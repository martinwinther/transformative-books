rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isVerifiedEmail() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function validUserMeta(data) {
      return data.keys().hasOnly(['createdAt', 'updatedAt', 'lastLoginAt', 'migrationVersion']) &&
        (!('createdAt' in data) || data.createdAt is timestamp) &&
        (!('updatedAt' in data) || data.updatedAt is timestamp) &&
        (!('lastLoginAt' in data) || data.lastLoginAt is timestamp) &&
        (!('migrationVersion' in data) || (data.migrationVersion is int && data.migrationVersion >= 0 && data.migrationVersion <= 10));
    }

    function validProgressData(data) {
      return data.keys().hasOnly(['isRead', 'owns', 'userRating', 'notes', 'updatedAt', 'updatedByDevice']) &&
        data.isRead is bool &&
        data.owns is bool &&
        (data.userRating == null || (data.userRating is int && data.userRating >= 1 && data.userRating <= 5)) &&
        data.notes is string &&
        data.notes.size() <= 5000 &&
        data.updatedAt is timestamp &&
        data.updatedByDevice is string &&
        data.updatedByDevice.size() <= 120;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isVerifiedEmail() && validUserMeta(request.resource.data);
      allow delete: if false;

      match /bookProgress/{slug} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && isVerifiedEmail() && validProgressData(request.resource.data);
        allow delete: if isOwner(uid) && isVerifiedEmail();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
